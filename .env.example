# Required: the bot token from the Discord Developer Portal.
DISCORD_TOKEN=<your_bot_token_here>

# Optional: path to the SQLite database file (will have fallbacks if it does not exist).
DATABASE_PATH=<database_path_here>

# Optional: comma-separated Discord channel IDs to restrict score parsing.
# If unset or empty, the bot processes messages from all channels.
# Example: DISCORD_FILTER_CHANNEL_IDS=123456789012345678,987654321098765432
DISCORD_FILTER_CHANNEL_IDS=<channel-ids>

# Optional: comma-separated Discord user IDs that have admin privileges.
# Example: DISCORD_ADMIN_USER_IDS=123456789012345678,987654321098765432
DISCORD_ADMIN_USER_IDS=

# Optional: Discord guild (server) ID where admin-only commands are registered.
# When set, commands like /backfill are only visible in this guild.
# Example: DISCORD_ADMIN_GUILD_ID=123456789012345678
DISCORD_ADMIN_GUILD_ID=

# Optional: Discord channel ID where bots can write logging to.
# This channel will be found in the DISCORD_ADMIN_GUILD as set by DISCORD_ADMIN_GUILD_ID
# Therefore, DISCORD_ADMIN_GUILD_ID is required in order to set DISCORD_LOGGING_CHANNEL_ID
# Example: DISCORD_LOGGING_CHANNEL_ID=123456789012345678
DISCORD_LOGGING_CHANNEL_ID=<channel-id>
