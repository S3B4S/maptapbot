# Required: the bot token from the Discord Developer Portal.
DISCORD_TOKEN=your_bot_token_here

# Optional: path to the SQLite database file (will have fallbacks if it does not exist).
DATABASE_PATH=database_path_here

# Optional: comma-separated Discord channel IDs to restrict score parsing.
# If unset or empty, the bot processes messages from all channels.
# Example: DISCORD_CHANNEL_IDS=123456789012345678,987654321098765432
DISCORD_CHANNEL_IDS=

# Optional: comma-separated Discord channel IDs where bots can write logging to.
# Example: DISCORD_LOGGING_CHANNEL_IDS=123456789012345678,987654321098765432
DISCORD_LOGGING_CHANNEL_IDS=

# Optional: comma-separated Discord user IDs that have admin privileges.
# Example: ADMIN_IDS=123456789012345678,987654321098765432
ADMIN_IDS=

# Optional: Discord guild (server) ID where admin-only commands are registered.
# When set, commands like /backfill are only visible in this guild.
# Example: ADMIN_GUILD_ID=123456789012345678
ADMIN_GUILD_ID=
